{
  "manifest_version": 3,
  "name": "ReleaseDiff",
  "version": "1.0.0",
  "description": "Quickly compare staging (including CMS) and production pages after release to spot visual differences",
  "permissions": [
    "storage",
    "scripting",
    "tabs"
  ],
  "optional_host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon.png",
      "32": "icons/icon.png",
      "48": "icons/icon.png",
      "128": "icons/icon.png"
    },
    "default_popup": "popup.html",
    "default_title": "ReleaseDiff"
  },
  "icons": {
    "16": "icons/icon.png",
    "32": "icons/icon.png",
    "48": "icons/icon.png",
    "128": "icons/icon.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
